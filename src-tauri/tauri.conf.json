{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Waqyay",
  "version": "0.1.0",
  "identifier": "com.xiza.waqyay",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Waqyay",
        "width": 960,
        "height": 640,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "publisher": "Xiza",
    "copyright": "Copyright © 2026 Xiza",
    "category": "Productivity",
    "shortDescription": "Recordatorios imposibles de ignorar",
    "longDescription": "Waqyay (quechua: 'llamar') es una app de escritorio para Windows con recordatorios de intrusividad configurable: desde un toast discreto hasta un overlay fullscreen con cuenta regresiva. Incluye tipos once / recurrente (intervalo o cron) / pomodoro, snooze, quiet hours, sonidos personalizados y push móvil via ntfy.sh.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "wix": {
        "language": "en-US",
        "upgradeCode": "a3f4e5c8-6b2d-4f1a-9c7e-0d8b3a5f9e2c"
      }
    }
  }
}
